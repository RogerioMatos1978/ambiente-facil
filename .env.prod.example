# ---------- Preencha com o IP fixo do PC que vai servir a intranet ----------
# Exemplo: se o PC tem IP 192.168.1.50 na rede local, use esse valor abaixo
# nas linhas marcadas com <IP-DO-PC>.

# ---------- Django / Backend ----------
DJANGO_SETTINGS_MODULE=config.settings.lan
DJANGO_SECRET_KEY=troque-por-uma-chave-forte-e-unica
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<IP-DO-PC>,localhost,127.0.0.1

# URL pública do frontend — usada para montar o link do QR code de cada
# ambiente. Precisa ser o MESMO endereço que os PCs da rede vão usar.
FRONTEND_URL=http://<IP-DO-PC>

# PostgreSQL
POSTGRES_DB=ambiente_facil
POSTGRES_USER=ambiente_facil
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (Channels / cache)
REDIS_HOST=redis
REDIS_PORT=6379

# CORS / CSRF — precisam bater com o endereço que os PCs da rede vão digitar
# (ao contrário de DJANGO_ALLOWED_HOSTS, aqui PRECISA do http://)
CORS_ALLOWED_ORIGINS=http://<IP-DO-PC>
CSRF_TRUSTED_ORIGINS=http://<IP-DO-PC>

# E-mail (opcional; deixe console se não for configurar SMTP agora)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Ambiente Fácil <noreply@ambientefacil.local>

# WhatsApp
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# Liberação automática de reservas por no-show (check-in não confirmado)
NO_SHOW_SCHEDULER_ATIVO=True
NO_SHOW_INTERVALO_MINUTOS=5

# ---------- Frontend ----------
# Precisa ser o MESMO endereço que os outros PCs vão usar no navegador,
# COM http:// na frente e SEM porta no final.
NEXT_PUBLIC_API_URL=http://<IP-DO-PC>
