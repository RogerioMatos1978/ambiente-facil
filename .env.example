# ---------- Django / Backend ----------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL
POSTGRES_DB=ambiente_facil
POSTGRES_USER=ambiente_facil
POSTGRES_PASSWORD=ambiente_facil
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (Channels / cache)
REDIS_HOST=redis
REDIS_PORT=6379

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# E-mail (use console backend em dev; configure SMTP em produção)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Ambiente Fácil <noreply@ambientefacil.local>

# WhatsApp
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
